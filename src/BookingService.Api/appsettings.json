{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=booking.db"
  },
  "Jwt": {
    "Key": "SuperSecretKeyForJwtMustBeAtLeast32CharactersLong!",
    "Issuer": "BookingService",
    "Audience": "BookingService",
    "ExpireMinutes": 120
  },
  "BookingLimits": {
    "MaxBookingsPerDay": 5
  }
}
